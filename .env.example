# Copiar a .env en la raíz (no versionar .env). Ver README y docs/specs/*.

# URL del API de stock compartido (sin barra final). En dispositivo físico: IP LAN del Mac, no localhost.
# Ej.: http://192.168.1.42:3000 — backend local con MONGODB_URI apuntando a DB de prueba.
EXPO_PUBLIC_BACKEND_URL=

# Mismo valor que API_KEY en backend/.env (ver docs/specs/backend-stock-api.md)
BACKEND_API_KEY=

NOTION_API_KEY=
NOTION_SUPPLEMENTS_DB_ID=
NOTION_PHASES_PAGE_ID=

# Opcional: pestaña Comidas (página con heading "Comidas Activas")
NOTION_MEAL_PREP_HUB_PAGE_ID=

# Solo desarrollo: si es true y __DEV__, no escribe fase/próximo ciclo en Notion tras HealthKit
# NOTION_SKIP_PHASE_WRITE=true
