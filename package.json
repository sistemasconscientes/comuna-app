{
  "name": "La Comuna App",
  "version": "1.2.1",
  "nativeBuild": 8,
  "main": "index.tsx",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client --lan --clear",
    "start:device": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0) expo start --dev-client --lan --clear",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "npm run version:check && jest",
    "version:check": "node scripts/sync-version.js --check",
    "version:sync": "node scripts/sync-version.js",
    "version:bump:feature": "node scripts/bump-feature-version.js",
    "version:bump:native": "node scripts/bump-native-build.js",
    "version": "npm run version:sync",
    "eas-build-pre-install": "node scripts/eas-preview-bump-native.js",
    "eas-build-post-install": "npm run version:sync",
    "eas:build:preview": "npm run version:bump:native && eas build --profile preview",
    "postinstall": "patch-package",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.claude/"
    ],
    "testMatch": [
      "**/*.test.ts",
      "**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@kingstinct/react-native-healthkit": "^14.0.1",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@sentry/react-native": "~7.11.0",
    "babel-plugin-dotenv-import": "^3.0.1",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "~56.0.12",
    "drizzle-orm": "^0.45.1",
    "expo": "~56.0.16",
    "expo-application": "~56.0.3",
    "expo-dev-client": "~56.0.23",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-localization": "~56.0.5",
    "expo-network": "~56.0.5",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.13",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.4",
    "posthog-react-native": "^4.45.14",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "14.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest-expo": "~56.0.5",
    "lint-staged": "16.4.0",
    "patch-package": "^8.0.1",
    "prettier": "3.8.3",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "rimraf": {
      ".": "^5.0.10",
      "glob": "^13.0.6"
    },
    "xcode": {
      "uuid": "^11.1.1"
    },
    "patch-package": {
      "tmp": "^0.2.6"
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
