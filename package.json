{
  "name": "comuna-app",
  "version": "1.0.0",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/*.test.ts",
      "**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@kingstinct/react-native-healthkit": "^13.3.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.4.18",
    "babel-plugin-dotenv-import": "^3.0.1",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "^55.0.11",
    "drizzle-orm": "^0.45.1",
    "expo": "~55.0.7",
    "expo-application": "~55.0.10",
    "expo-dev-client": "~55.0.17",
    "expo-device": "~55.0.10",
    "expo-file-system": "~55.0.11",
    "expo-localization": "~55.0.9",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "^55.0.10",
    "jest-expo": "^55.0.10",
    "posthog-react-native": "^4.37.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-reanimated": "4.2.1",
    "react-native-worklets": "^0.7.1",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
