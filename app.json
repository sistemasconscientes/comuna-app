{
  "expo": {
    "name": "La Comuna App",
    "slug": "comuna-app",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.janee.comunaapp",
      "buildNumber": "6",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "Usamos HealthKit para leer datos de tu ciclo menstrual y adaptar tus suplementos.",
        "NSHealthUpdateUsageDescription": "Usamos HealthKit para registrar datos de salud relevantes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ],
      "expo-dev-client",
      "expo-localization",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "La Comuna necesita leer tu ciclo menstrual para personalizar tus suplementos",
          "NSHealthUpdateUsageDescription": "La Comuna puede registrar datos de ciclo",
          "background": false
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "comunaapp",
          "organization": "sistemasconscientes"
        }
      ],
      "@sentry/react-native"
    ],
    "android": {
      "package": "com.janee.comunaapp",
      "versionCode": 6
    },
    "extra": {
      "eas": {
        "projectId": "4c8d61f7-1bc4-439c-8ba8-aefe7803c24e"
      }
    },
    "owner": "labsistemasconscientes"
  }
}
