{
  "expo": {
    "name": "La Comuna App",
    "slug": "comuna-app",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.janee.comunaapp",
      "buildNumber": "8",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "Usamos HealthKit para leer datos de tu ciclo menstrual y adaptar tus suplementos.",
        "NSHealthUpdateUsageDescription": "Usamos HealthKit para registrar datos de salud relevantes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#141210"
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ],
      "expo-dev-client",
      "expo-localization",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "La Comuna necesita leer tu ciclo menstrual para personalizar tus suplementos",
          "NSHealthUpdateUsageDescription": "La Comuna puede registrar datos de ciclo",
          "background": false
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "<YOUR_SENTRY_PROJECT>",
          "organization": "<YOUR_SENTRY_ORG>"
        }
      ],
      "@sentry/react-native",
      "expo-font",
      "expo-secure-store"
    ],
    "android": {
      "package": "com.janee.comunaapp",
      "versionCode": 8
    }
  }
}
